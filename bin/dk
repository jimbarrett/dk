#!/usr/bin/env php
<?php

require_once __DIR__ . '/../src/Docker/Client.php';

use Dk\Docker\Client;

$docker = new Client();

$command = $argv[1] ?? '';
$args = array_slice($argv, 2);

match ($command) {
    ''        => cmdStatus($docker),
    'ls'      => cmdList($docker, $args),
    'start'   => cmdStart($docker, $args),
    'stop'    => cmdStop($docker, $args),
    'restart' => cmdRestart($docker, $args),
    'sh'      => cmdShell($docker, $args),
    'logs'    => cmdLogs($docker, $args),
    'ports'   => cmdPorts($docker, $args),
    'rm'      => cmdRemove($docker, $args),
    'rmi'     => cmdRemoveImage($docker, $args),
    'clean'   => cmdClean($docker),
    'web'     => cmdWeb($args),
    'help'    => cmdHelp(),
    default   => cmdUnknown($command),
};

// ─── Commands ────────────────────────────────────────────────────────

function cmdStatus(Client $docker): void
{
    $containers = $docker->listContainers(true);
    $running = count(array_filter($containers, fn($c) => $c['state'] === 'running'));
    $stopped = count($containers) - $running;
    $images = $docker->listImages();

    echo "\033[1mdk — Docker Overview\033[0m\n\n";
    echo "  Running:  {$running} containers\n";
    echo "  Stopped:  {$stopped} containers\n";
    echo "  Images:   " . count($images) . "\n\n";

    if ($running > 0) {
        $active = array_filter($containers, fn($c) => $c['state'] === 'running');
        printContainerTable($active);
    }
}

function cmdList(Client $docker, array $args): void
{
    $all = in_array('-a', $args);
    $grouped = in_array('-g', $args);

    if ($grouped) {
        $data = $docker->listGrouped($all);

        foreach ($data['projects'] as $project => $containers) {
            $running = count(array_filter($containers, fn($c) => $c['state'] === 'running'));
            $total = count($containers);
            $color = $running === $total ? "\033[32m" : "\033[33m";
            echo "\n\033[1m{$project}\033[0m {$color}[{$running}/{$total} running]\033[0m\n";

            foreach ($containers as $c) {
                $name = str_pad(Client::shortName($c), 18);
                $image = str_pad($c['image'], 20);
                $status = str_pad($c['status'], 14);
                $ports = implode(', ', $c['ports']);
                $stateColor = $c['state'] === 'running' ? "\033[32m" : "\033[31m";
                echo "  {$stateColor}●\033[0m {$name} {$image} {$status} {$ports}\n";
            }
        }

        if (!empty($data['ungrouped'])) {
            echo "\n\033[1mUngrouped\033[0m\n";
            foreach ($data['ungrouped'] as $c) {
                $name = str_pad($c['name'], 18);
                $image = str_pad($c['image'], 20);
                $status = str_pad($c['status'], 14);
                $ports = implode(', ', $c['ports']);
                $stateColor = $c['state'] === 'running' ? "\033[32m" : "\033[31m";
                echo "  {$stateColor}●\033[0m {$name} {$image} {$status} {$ports}\n";
            }
        }
        echo "\n";
    } else {
        $containers = $docker->listContainers($all);
        if (empty($containers)) {
            echo "No containers found.\n";
            return;
        }
        printContainerTable($containers);
    }
}

function cmdStart(Client $docker, array $args): void
{
    $name = resolveContainer($docker, $args, false);
    if (!$name) return;
    echo $docker->start($name) . "\n";
    echo "\033[32mStarted:\033[0m {$name}\n";
}

function cmdStop(Client $docker, array $args): void
{
    $name = resolveContainer($docker, $args, true);
    if (!$name) return;
    echo $docker->stop($name) . "\n";
    echo "\033[33mStopped:\033[0m {$name}\n";
}

function cmdRestart(Client $docker, array $args): void
{
    $name = resolveContainer($docker, $args, true);
    if (!$name) return;
    echo $docker->restart($name) . "\n";
    echo "\033[32mRestarted:\033[0m {$name}\n";
}

function cmdShell(Client $docker, array $args): void
{
    $name = resolveContainer($docker, $args, true);
    if (!$name) return;
    $shell = $docker->detectShell($name);
    echo "Connecting to \033[1m{$name}\033[0m ({$shell})...\n";
    $code = $docker->shell($name);
    exit($code);
}

function cmdLogs(Client $docker, array $args): void
{
    $follow = in_array('-f', $args);
    $args = array_values(array_filter($args, fn($a) => $a !== '-f'));

    $name = resolveContainer($docker, $args, true);
    if (!$name) return;
    $code = $docker->logs($name, $follow);
    exit($code);
}

function cmdPorts(Client $docker, array $args): void
{
    if (!empty($args[0])) {
        $matches = $docker->findContainers($args[0]);
        if (empty($matches)) {
            echo "No running containers matching '{$args[0]}'.\n";
            return;
        }
        foreach ($matches as $c) {
            $ports = implode(', ', $c['ports']) ?: 'none';
            echo "\033[1m{$c['name']}\033[0m  {$ports}\n";
        }
    } else {
        $containers = $docker->listContainers();
        if (empty($containers)) {
            echo "No running containers.\n";
            return;
        }
        $maxName = max(array_map(fn($c) => strlen($c['name']), $containers));
        foreach ($containers as $c) {
            $name = str_pad($c['name'], $maxName);
            $ports = implode(', ', $c['ports']) ?: 'none';
            echo "{$name}  {$ports}\n";
        }
    }
}

function cmdRemove(Client $docker, array $args): void
{
    $force = in_array('-f', $args);
    $args = array_values(array_filter($args, fn($a) => $a !== '-f'));

    $name = resolveContainer($docker, $args, false);
    if (!$name) return;

    echo $docker->remove($name, $force) . "\n";
    echo "\033[31mRemoved:\033[0m {$name}\n";
}

function cmdRemoveImage(Client $docker, array $args): void
{
    $force = in_array('-f', $args);
    $args = array_values(array_filter($args, fn($a) => $a !== '-f'));

    if (empty($args[0])) {
        $images = $docker->listImages();
        if (empty($images)) {
            echo "No images found.\n";
            return;
        }
        echo "Select an image to remove:\n";
        foreach ($images as $i => $img) {
            $label = $img['repo'] . ':' . $img['tag'];
            echo "  \033[1m" . ($i + 1) . ")\033[0m {$label}  ({$img['size']})\n";
        }
        $choice = prompt('> ');
        $idx = intval($choice) - 1;
        if (!isset($images[$idx])) {
            echo "Invalid selection.\n";
            return;
        }
        $target = $images[$idx]['id'];
    } else {
        $target = $args[0];
    }

    echo $docker->removeImage($target, $force) . "\n";
    echo "\033[31mRemoved image.\033[0m\n";
}

function cmdClean(Client $docker): void
{
    echo "Pruning stopped containers, dangling images, and unused volumes...\n";
    echo $docker->clean() . "\n";
    echo "\033[32mDone.\033[0m\n";
}

function cmdWeb(array $args): void
{
    $port = $args[0] ?? '8080';
    $webDir = __DIR__ . '/../web';
    echo "Starting dk web UI on \033[1mhttp://localhost:{$port}\033[0m\n";
    echo "Press Ctrl+C to stop.\n\n";
    passthru("php -S localhost:{$port} -t " . escapeshellarg($webDir));
}

function cmdHelp(): void
{
    echo <<<HELP
    \033[1mdk — Docker management CLI\033[0m

    Usage: dk <command> [options]

    Commands:
      (none)      Status overview
      ls          List containers (-a all, -g grouped)
      start       Start a container
      stop        Stop a container
      restart     Restart a container
      sh          Shell into a container
      logs        Tail logs (-f to follow)
      ports       Show port mappings
      rm          Remove a container (-f force)
      rmi         Remove an image (-f force)
      clean       Prune stopped containers, dangling images, volumes
      web         Launch web UI (optional port, default 8080)
      help        Show this help

    Container names support partial matching. Omit the name for interactive selection.

    HELP;
}

function cmdUnknown(string $command): void
{
    echo "Unknown command: {$command}\n";
    echo "Run 'dk help' for usage.\n";
}

// ─── Helpers ─────────────────────────────────────────────────────────

function resolveContainer(Client $docker, array $args, bool $runningOnly): ?string
{
    if (!empty($args[0])) {
        $matches = $docker->findContainers($args[0], $runningOnly);
        if (empty($matches)) {
            $scope = $runningOnly ? 'running ' : '';
            echo "No {$scope}containers matching '{$args[0]}'.\n";
            return null;
        }
        if (count($matches) === 1) {
            return $matches[0]['name'];
        }
        echo "Multiple containers match '{$args[0]}':\n";
        return pickContainer($matches);
    }

    $containers = $docker->listContainers(!$runningOnly);
    if (empty($containers)) {
        echo "No containers found.\n";
        return null;
    }

    echo "Select a container:\n";
    return pickContainer($containers);
}

function pickContainer(array $containers): ?string
{
    foreach ($containers as $i => $c) {
        $stateColor = $c['state'] === 'running' ? "\033[32m" : "\033[31m";
        echo "  \033[1m" . ($i + 1) . ")\033[0m {$stateColor}●\033[0m {$c['name']}\n";
    }
    $choice = prompt('> ');
    $idx = intval($choice) - 1;
    if (!isset($containers[$idx])) {
        echo "Invalid selection.\n";
        return null;
    }
    return $containers[$idx]['name'];
}

function prompt(string $label): string
{
    echo $label;
    return trim(fgets(STDIN));
}

function printContainerTable(array $containers): void
{
    $maxName = max(array_map(fn($c) => strlen($c['name']), $containers));
    $maxImage = max(array_map(fn($c) => strlen($c['image']), $containers));
    $nameW = max($maxName, 9);
    $imageW = max($maxImage, 5);

    $header = str_pad('CONTAINER', $nameW) . '  '
        . str_pad('IMAGE', $imageW) . '  '
        . str_pad('STATUS', 14) . '  '
        . 'PORTS';
    echo "\033[1m{$header}\033[0m\n";

    foreach ($containers as $c) {
        $name = str_pad($c['name'], $nameW);
        $image = str_pad($c['image'], $imageW);
        $status = str_pad($c['status'], 14);
        $ports = implode(', ', $c['ports']);
        echo "{$name}  {$image}  {$status}  {$ports}\n";
    }
}
